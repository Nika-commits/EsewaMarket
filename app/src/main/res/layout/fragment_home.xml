<?xml version="1.0" encoding="utf-8"?>


<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activities.MainActivity"
    android:background="@color/offWhiteBackground"
    >

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:elevation="4dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/logo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/app_name"
                android:src="@drawable/resource_default"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:text="@string/app_name"
                android:textAppearance="@style/ToolbarTitle"
                android:textColor="@color/lightGrey"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/logo"
                android:includeFontPadding="false"
                android:layout_marginBottom="-4dp"
                android:gravity="bottom"
                android:letterSpacing="0.02"
                android:fontFamily="@font/source_sans_regular"

                />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.appcompat.widget.Toolbar>

    <LinearLayout
        android:id="@+id/greetings"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintLeft_toLeftOf="parent"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Goodmorning"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:fontFamily="@font/source_sans_regular"
            android:textSize="10sp"
            android:letterSpacing="0.03"
            android:textColor="@color/lightGrey"
            />

        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:fontFamily="@font/source_sans_bold"
            android:textSize="10sp"
            android:letterSpacing="0.03"
            android:paddingHorizontal="4dp"
            android:textColor="@color/lightGrey"
            />
        <TextView
            android:text="Everything you will discover here"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:fontFamily="@font/source_sans_regular"
            android:textSize="10sp"
            android:letterSpacing="0.03"
            android:textColor="@color/lightGrey"
            />
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/searchBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/greetings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="12dp"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:startIconDrawable="@drawable/ic_search"
        app:startIconTint="@color/lightGrey"
        app:endIconTint="@color/lightGrey"
        app:endIconDrawable="@drawable/ic_slider"
        app:endIconMode="custom"
        android:hint="What are you searching for ? "
        android:textColorHint="@color/light"
        app:hintTextColor="@color/textLight"
        app:cursorColor="@color/lightGrey"
        app:boxBackgroundMode="filled"
        app:boxBackgroundColor="@color/surface"
        app:boxStrokeWidth="0dp"
        >

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:typeface="normal"
            android:inputType="text"
            android:maxLines="1"
            android:textColor="@color/black"
            android:textColorHint="@color/textLight"
            android:layout_height="wrap_content"/>

    </com.google.android.material.textfield.TextInputLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/heroViewPager"
        app:layout_constraintTop_toBottomOf="@id/searchBox"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:paddingTop="12dp"
        android:paddingBottom="2dp"
        android:layout_width="368dp"
        android:layout_height="148dp"/>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/heroIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:background="@android:color/transparent"
        android:elevation="0dp"

        app:layout_constraintTop_toBottomOf="@id/heroViewPager"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        app:tabIndicator="@null"
        app:tabIndicatorHeight="0dp"
        app:tabRippleColor="@null"

        app:tabMinWidth="0dp"
        app:tabPaddingStart="4dp"
        app:tabPaddingEnd="4dp"

        app:tabGravity="center"
        app:tabMode="fixed"/>

    <include
        android:id="@+id/rvCategoryOptionsLayout"
        layout="@layout/section_categories"
        android:layout_height="wrap_content"
        android:layout_width="0dp"
        app:layout_constraintTop_toBottomOf="@id/heroIndicator"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        />

<!--    <include-->
<!--        android:id="@+id/featuredProductsSection"-->
<!--        layout="@layout/section_featured_products"-->
<!--        app:layout_constraintTop_toBottomOf="@id/rvCategoryOptionsLayout"-->
<!--        app:layout_constraintLeft_toLeftOf="parent"-->
<!--        app:layout_constraintRight_toRightOf="parent"-->
<!--        />-->

</androidx.constraintlayout.widget.ConstraintLayout>